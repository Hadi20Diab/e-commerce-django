# ── Django ────────────────────────────────────────────────────────────────────
# Generate a secure key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REPLACE_WITH_SECURE_SECRET_KEY
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourapp.railway.app

# PostgreSQL (provided by Railway plugin — copy the full URL from the Railway dashboard)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Your Vercel frontend URL (used for CORS + CSRF)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# ── Stripe ────────────────────────────────────────────────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
# Live keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Webhook secret — Railway: use Stripe CLI or add endpoint in Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=REPLACE_WITH_APP_PASSWORD
DEFAULT_FROM_EMAIL=LUXE Store <your@gmail.com>
